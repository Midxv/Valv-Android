<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="1dp">

    <!-- The 1:1 Card that holds everything -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardImage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <se.arctosoft.vault.views.PressableConstraintLayout
            android:id="@+id/layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- The Thumbnail Image -->
            <se.arctosoft.vault.views.GridImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Text file preview placeholder -->
            <se.arctosoft.vault.views.PressableGridTextView
                android:id="@+id/textView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:padding="8dp"
                android:visibility="gone" />

            <!-- Selection Checkbox -->
            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:layout_marginTop="2dp"
                android:clickable="false"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Video/Gif Icon Indicator -->
            <ImageView
                android:id="@+id/imgType"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="6dp"
                android:src="@drawable/ic_round_gif_24"
                android:visibility="gone"
                app:tint="@android:color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Note/Description Indicator -->
            <ImageView
                android:id="@+id/has_description"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="4dp"
                android:src="@drawable/outline_text_snippet_24"
                android:visibility="gone"
                app:tint="@android:color/white"
                app:layout_constraintEnd_toStartOf="@id/imgType"
                app:layout_constraintTop_toTopOf="@id/imgType"
                app:layout_constraintBottom_toBottomOf="@id/imgType"/>

            <!-- THE NEW CUTE OVERLAY TEXT -->
            <!-- Anchored to the bottom of the card, with translucent dark glass styling -->
            <TextView
                android:id="@+id/txtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#99000000"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="middle"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </se.arctosoft.vault.views.PressableConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>